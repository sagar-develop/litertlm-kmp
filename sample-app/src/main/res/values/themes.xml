<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Launch theme using the AndroidX splash-screen API. The system shows the
         brand mark on the off-white canvas before the Compose UI is ready, then
         hands off to the app theme. -->
    <style name="Theme.NativeLM.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.NativeLM</item>
    </style>

    <!-- App theme. NoActionBar; Compose draws everything. -->
    <style name="Theme.NativeLM" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/ic_launcher_background</item>
    </style>

</resources>
